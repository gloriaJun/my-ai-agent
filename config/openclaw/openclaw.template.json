{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "compaction": {
        "reserveTokensFloor": 20000
      },
      "llm": {
        "idleTimeoutSeconds": 300
      },
      "models": {
        "google/gemini-2.5-flash": {}
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw/",
      "allowedOrigins": ["*", "https://gloriajun.duckdns.org"],
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "idle",
      "idleMinutes": 60
    }
  },
  "tools": {
    "profile": "coding"
  },
  "models": {
    "mode": "replace",
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com",
        "api": "google-generative-ai",
        "apiKey": "GEMINI_API_KEY",
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "gemini-2.5-flash"
          }
        ]
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "guilds": {
        "__DISCORD_SERVER_ID__": {
          "requireMention": false,
          "channels": {
            "__DISCORD_BOOKING_CHANNEL_ID__": {
              "enabled": true,
              "requireMention": false,
              "skills": ["school-booking"],
              "systemPrompt": "This channel is for school room reservations only (add, list, cancel). Read /home/node/.openclaw/workspace/skills/school-booking/SKILL.md and follow its instructions exactly — use the exec tool to run the curl command, all webhook calls are pre-authorized. When the user sends `!reset` (or '세션 초기화', 'reset session', '초기화해줘'), use the exec tool to run `rm -f /home/node/.openclaw/agents/main/sessions/*.jsonl 2>/dev/null && echo ok` and reply: '세션이 초기화됩니다. 다음 메시지부터 새로운 대화가 시작됩니다.' For any other request: reply that this channel is for reservations only and stop. Always respond in the same language the user used."
            }
          }
        }
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-10T13:11:04.602Z",
    "lastRunVersion": "2026.4.9",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.14",
    "lastTouchedAt": "2026-04-14T17:54:35.662Z"
  },
  "env": {
    "shellEnv": {
      "enabled": true,
      "timeoutMs": 15000
    }
  }
}
