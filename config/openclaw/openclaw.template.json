{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "ollama/llama3.2:3b",
        "fallbacks": ["google/gemini-2.5-flash"]
      },
      "compaction": {
        "reserveTokensFloor": 20000
      },
      "llm": {
        "idleTimeoutSeconds": 300
      },
      "models": {
        "ollama/llama3.2:3b": {},
        "google/gemini-2.5-flash": {}
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw/",
      "allowedOrigins": ["*", "https://gloriajun.duckdns.org"],
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding"
  },
  "models": {
    "mode": "replace",
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434",
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY",
        "models": []
      },
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com",
        "api": "google-generative-ai",
        "apiKey": "GEMINI_API_KEY",
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "gemini-2.5-flash"
          }
        ]
      }
    }
  },
  "auth": {
    "profiles": {
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOOKING_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "destinations": {
        "n8n_booking": {
          "type": "webhook",
          "url": "${N8N_BOOKING_WEBHOOK_URL}",
          "method": "POST"
        }
      },
      "guilds": {
        "__DISCORD_SERVER_ID__": {
          "requireMention": false,
          "channels": {
            "__DISCORD_BOOKING_CHANNEL_ID__": {
              "enabled": true,
              "requireMention": false,
              "destination": "n8n_booking"
            }
          }
        }
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-10T13:11:04.602Z",
    "lastRunVersion": "2026.4.9",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.14",
    "lastTouchedAt": "2026-04-14T17:54:35.662Z"
  },
  "plugins": {
    "entries": {
      "ollama": {
        "enabled": true
      }
    }
  },
  "env": {
    "shellEnv": {
      "enabled": true,
      "timeoutMs": 15000
    }
  }
}
